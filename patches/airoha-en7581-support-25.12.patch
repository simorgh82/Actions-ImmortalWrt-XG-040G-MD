- 		}
- 	      
--	      rdlen -= p[1];
--	      p +=  p[1];
-+	      rdlen -= p[1] + 2;
-+	      p +=  p[1] + 2;
- 	    }
- 	  
- 	  return 0;
-@@ -1433,7 +1433,7 @@ static int check_nsec3_coverage(struct d
- 		p += hash_len; /* skip next-domain hash */
- 		rdlen -= p - psave;
- 
--		if (rdlen >= 2 && p[0] == 0)
-+		if (rdlen >= 2 && p[0] == 0 && p[1] >= 1)
- 		  {
- 		    /* If we can prove that there's no NS record, return that information. */
- 		    if (nons && (p[2] & (0x80 >> T_NS)) != 0)
-@@ -1462,8 +1462,8 @@ static int check_nsec3_coverage(struct d
- 			break; /* finished checking */
- 		      }
- 		    
--		    rdlen -= p[1];
--		    p +=  p[1];
-+		    rdlen -= p[1] + 2;
-+		    p +=  p[1] + 2;
- 		  }
- 		
- 		return 1;
